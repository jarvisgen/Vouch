# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
WORKER_MODEL=claude-sonnet-4-6
AUDITOR_MODEL=claude-opus-4-8

# ---- Sui ----
SUI_NETWORK=testnet
SUI_RPC=https://fullnode.testnet.sui.io:443
# Either provide a base64/bech32 keypair, or leave blank to use the active CLI address.
SUI_KEYPAIR=
# Separate auditor keypair (the on-chain resolution oracle).
AUDITOR_KEYPAIR=

# ---- Walrus (testnet) ----
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=5

# ---- Stablecoin ----
# real = use testnet USDC coin type; mock = use vouch::mock_usdc faucet
STABLECOIN_MODE=real
USDC_COIN_TYPE=

# ---- Deployment (filled by scripts/publish.ts) ----
VOUCH_PACKAGE_ID=
AGENT_REGISTRY_ID=
