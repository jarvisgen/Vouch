{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npx --yes pnpm@9 install --no-frozen-lockfile",
  "buildCommand": "npx --yes pnpm@9 --filter @vouch/web build",
  "outputDirectory": "web/dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
